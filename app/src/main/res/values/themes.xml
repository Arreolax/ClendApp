<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ClendApp" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.ClendApp" parent="Base.Theme.ClendApp" />

    <style name="CalendarDayLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#999999</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingVertical">8dp</item>
    </style>

    <style name="CalendarDayNumber">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#2A2A2A</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="CalendarDayNumberMuted" parent="CalendarDayNumber">
        <item name="android:textColor">#CCCCCC</item>
    </style>

    <style name="CalendarDayNumberActive" parent="CalendarDayNumber">
        <item name="android:textColor">#6B9CFF</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CalendarDayContainer">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_columnWeight">1</item>
    </style>

    <style name="ShapeAppearance.NoCorner" parent="">
        <item name="cornerSize">0dp</item>
    </style>
</resources>